{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/back-end/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frent-end/dist/$1"
    }
  ],
  "builds": [
    {
      "src": "/back-end/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "/frent-end/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ]
}
