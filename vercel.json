{
  "buildCommand": "cd frent-end && npm run build",
  "outputDirectory": "frent-end/dist",
  "devCommand": "cd frent-end && npm run dev",
  "installCommand": "cd frent-end && npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/frent-end/dist/index.html"
    }
  ]
}
